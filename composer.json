{
  "name": "libelulibelu/yii2-error-handler",
  "description": "Error handler for mongo databases",
  "type": "yii2-extension",
  "keywords": [
    "yii2",
    "extension"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Johnny Garcia",
      "email": "johnnygar98@hotmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "yiisoft/yii2": "~2.0.54",
    "mongodb/mongodb": "^2.3",
    "yiisoft/yii2-mongodb": "^3.0",
    "symfony/mailer": "^7.4.12",
    "libelulibelu/yii2-common-helpers": "~1.0"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "autoload": {
    "psr-4": {
      "Libelula\\ErrorHandler\\": "src"
    }
  },
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}
