#!/bin/sh
#
# Pre-commit hook: runs the test suite and blocks the commit when it fails.
# Wired up automatically by `composer install` (sets core.hooksPath to .githooks).

echo "Running test suite before commit..."

if command -v composer >/dev/null 2>&1; then
    composer test
    status=$?
else
    ./vendor/bin/phpunit
    status=$?
fi

if [ "$status" -ne 0 ]; then
    echo "Tests failed - aborting commit. Fix the failures or use --no-verify to bypass."
fi

exit "$status"
